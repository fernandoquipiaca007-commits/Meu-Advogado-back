# ===========================================
# Railway Environment Variables (Backend)
# ===========================================
# Cópia para configurar no Railway Dashboard

# Spring Profile (OBRIGATÓRIO - use "prod")
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL (Railway fornece DATABASE_URL, converter para JDBC)
# DATABASE_URL vem como: postgresql://user:pass@host:port/dbname
# Converter para:
SPRING_DATASOURCE_URL=jdbc:postgresql://host:port/dbname?sslmode=require
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=pass

# JWT
JWT_SECRET=gerar-uma-chave-segura-de-pelo-menos-32-caracteres
JWT_EXPIRES_IN=3600000
JWT_REFRESH_EXPIRES_IN=7200000

# URLs (OBRIGATÓRIO)
FRONTEND_URL=https://meu-advogado-front.vercel.app
BACKEND_URL=https://backend-production-xxxx.up.railway.app

# Server
PORT=8080
DEBUG=false

# Mail (SMTP)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=sua-senha-de-app
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
