# ============================================================
# .ENV PARA RAILWAY - COLAR NO DASHBOARD
# ============================================================
# Instruções:
# 1. Copia todo este bloco
# 2. Vai a Railway > Meu-Advogado-back > Variables
# 3. Clica em "Bulk Import" ou adiciona uma a uma
# 4. Substitui os valores marcados com << >> pelos teus dados
# ============================================================

# === OBRIGATÓRIO ===
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# === SUPABASE - Conexão à Base de Dados ===
# Connection String do Supabase:
# postgresql://postgres:<<SUA_SENHA>>@db.<<SEU_REF>>.supabase.co:6543/postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<<SEU_REF>>.supabase.co:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<<SUA_SENHA_SUPABASE>>

# === JWT - Segurança ===
# Qualquer string com 32+ caracteres
JWT_SECRET=mude-esta-chave-para-uma-string-segura-32-caracteres!

# === URLS - CORS e Emails ===
FRONTEND_URL=https://meu-advogado-front.vercel.app
BACKEND_URL=https://<<SEU-BACKEND>>.up.railway.app

# === EMAIL - Opcional (para verificação e reset de password) ===
# Se usares Gmail, precisas de uma "App Password" (senha de app)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=senha-de-app-do-gmail

# === OPCIONAIS (já têm valor default, só se quiseres mudar) ===
# JWT_EXPIRES_IN=3600000
# JWT_REFRESH_EXPIRES_IN=7200000
# JWT_COOKIE_NAME=jwt_token
# JWT_REFRESH_COOKIE_NAME=jwt_refresh_token
# JWT_COOKIE_MAX_AGE=86400
# DEBUG=false
