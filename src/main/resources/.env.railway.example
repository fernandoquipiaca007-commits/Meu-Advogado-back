# ============================================
# COLAR NO RAILWAY DASHBOARD
# ============================================
# 1. Vai a Railway > Meu-Advogado-back > Variables
# 2. Clica "Bulk Import" e cola isto
# 3. Substitui os << >> pelos teus dados
# ============================================

SPRING_PROFILES_ACTIVE=prod
PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://db.<<SEU_REF>>.supabase.co:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<<SUA_SENHA_SUPABASE>>

JWT_SECRET=mude-esta-chave-para-uma-string-segura-com-32-caracteres

FRONTEND_URL=https://meu-advogado-front.vercel.app
BACKEND_URL=https://<<SEU-BACKEND>>.up.railway.app
