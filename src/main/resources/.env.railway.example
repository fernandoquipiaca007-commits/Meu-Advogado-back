# =============================================================================
# VARIÁVEIS DE AMBIENTE — RAILWAY (Backend)
# =============================================================================
# Copie e cole estas variáveis no painel do Railway > Variables
# =============================================================================

# --- Profile ---
SPRING_PROFILES_ACTIVE=prod

# --- Database (PostgreSQL Railway) ---
# Use uma das duas opções:
# Opção 1: Configurar cada variável individualmente no Railway
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<dbname>?sslmode=require
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>

# Opção 2: Usar a DATABASE_URL fornecida pelo Railway (formato postgresql://user:pass@host:port/db)
# Nota: Se usar DATABASE_URL, configure um script de inicialização ou use o parser do Railway.

# --- JWT ---
JWT_SECRET=<sua-chave-secreta-jwt-256bits>
JWT_EXPIRES_IN=3600000
JWT_REFRESH_EXPIRES_IN=7200000
JWT_COOKIE_NAME=jwt_token
JWT_REFRESH_COOKIE_NAME=jwt_refresh_token
JWT_COOKIE_MAX_AGE=86400

# --- CORS ---
FRONTEND_URL=https://meu-advogado-front.vercel.app

# --- Server ---
PORT=8080
DEBUG=false

# --- Mail SMTP (Gmail) ---
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=sua-senha-de-app
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# --- Stripe (se aplicável) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# VARIÁVEIS DE AMBIENTE — VERCEL (Frontend)
# =============================================================================
# Configure estas variáveis no painel da Vercel > Seu Projeto > Settings > Environment Variables
# =============================================================================

VITE_API_URL=https://<seu-backend>.up.railway.app
