# ============================================================
# VARIÁVEIS DE AMBIENTE - BACKEND (Railway)
# ============================================================
# 1. Ativar profile de produção (OBRIGATÓRIO)
SPRING_PROFILES_ACTIVE=prod

# ============================================================
# 2. CONEXÃO SUPABASE (OBRIGATÓRIO)
# Obter em: Supabase Dashboard > Project Settings > Database
#
# DATABASE_URL (formato Railway): postgresql://postgres:senha@db.projeto.supabase.co:6543/postgres
#
# Converter para JDBC:
# SPRING_DATASOURCE_URL = jdbc:postgresql://db.projeto.supabase.co:6543/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME = postgres
# SPRING_DATASOURCE_PASSWORD = <senha_do_banco>
# ============================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-password

# ============================================================
# 3. JWT (OBRIGATÓRIO)
# ============================================================
JWT_SECRET=uma-chave-secreta-com-pelo-menos-32-caracteres!
JWT_EXPIRES_IN=3600000
JWT_REFRESH_EXPIRES_IN=7200000
JWT_COOKIE_NAME=jwt_token
JWT_REFRESH_COOKIE_NAME=jwt_refresh_token
JWT_COOKIE_MAX_AGE=86400

# ============================================================
# 4. URLs (OBRIGATÓRIO)
# ============================================================
# URL do frontend (Vercel) - usada para CORS e links em emails
FRONTEND_URL=https://meu-advogado-front.vercel.app

# URL do backend (Railway) - usada para links de verificação em emails
BACKEND_URL=https://meu-advogado-back.up.railway.app

# ============================================================
# 5. SERVIDOR (OBRIGATÓRIO)
# ============================================================
PORT=8080

# ============================================================
# 6. EMAIL (OPCIONAL - necessário para recuperação de senha)
# ============================================================
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=sua-senha-de-app
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ============================================================
# 7. DEBUG (OPCIONAL)
# ============================================================
DEBUG=false
