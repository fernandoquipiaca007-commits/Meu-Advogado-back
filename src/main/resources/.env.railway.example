# === Railway Environment Variables Example ===
# Copy this file, rename to remove .example, and fill in your values
# Or set these directly in Railway Dashboard > Variables

# Spring profile (must be "prod" for Railway)
SPRING_PROFILES_ACTIVE=prod

# === Supabase Database (PostgreSQL) ===
# Get these from: Supabase Dashboard > Project Settings > Database > Connection string
# URI format: postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres
# JDBC format (use this for SPRING_DATASOURCE_URL):
SPRING_DATASOURCE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-password

# === JWT Security ===
JWT_SECRET=your-secret-key-with-at-least-32-characters
JWT_EXPIRES_IN=3600000
JWT_REFRESH_EXPIRES_IN=7200000

# === URLs ===
FRONTEND_URL=https://meu-advogado-front.vercel.app
BACKEND_URL=https://meu-advogado-back.up.railway.app

# === Server ===
PORT=8080

# === Mail (SMTP - optional) ===
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@gmail.com
# SPRING_MAIL_PASSWORD=your-app-password
